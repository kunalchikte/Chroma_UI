# Chroma UI adapter — copy this file to `.env` next to it and adjust.
#   cp .env.example .env
# Loaded automatically when you run `npm run dev` / `npm start` from the `backend/` workspace
# (working directory is typically `backend/`). Real secrets stay in `.env` (gitignored).

# --- Upstream Chroma HTTP API (required to point at your instance) ---
CHROMA_URL=http://localhost:8000

# --- Adapter listen address (Express) ---
HOST=127.0.0.1
PORT=8787

# --- Optional: Bearer token sent to Chroma on every upstream request ---
# CHROMA_TOKEN=

# --- Optional: timeouts & limits (milliseconds / counts) ---
# CHROMA_HEALTH_TIMEOUT_MS=2500
# CHROMA_READ_TIMEOUT_MS=12000

# How long GET /collections responses are cached server-side
# COLLECTIONS_CACHE_TTL_MS=25000

# Hard caps (server also clamps absolute maximums internally)
# SAMPLE_HARD_CAP=50
# QUERY_HARD_CAP=40
